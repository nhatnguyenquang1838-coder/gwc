---
const githubUrl = 'https://github.com/YOUR_USERNAME/YOUR_REPO';
---

<section class="hero" id="top">
     <div class="hero-bg">
         <img src="/images/hero.jpg" alt="" class="hero-bg-img" loading="eager" />
         <div class="hero-overlay"></div>
     </div>

     <div class="hero-content">
         <span class="hero-badge anim anim-1">Build & Ship Faster</span>

         <h1 class="hero-title anim anim-2">
             <span class="hero-grad">Understand</span> Your Code
         </h1>

         <p class="hero-tagline anim anim-3">
             See your codebase's story &mdash; dependencies, flows, and domains.
         </p>

         <div class="hero-pillars anim anim-4">
             <span class="pillar">Structure & Dependencies</span>
             <span class="pillar-dot">&middot;</span>
             <span class="pillar">Business Logic</span>
             <span class="pillar-dot">&middot;</span>
             <span class="pillar">Guided Exploration</span>
         </div>

         <div class="hero-actions anim anim-5">
             <a href="#install" class="hero-cta"><span>Get Started</span></a>
             <a href="#live-demo" class="hero-demo">Live Demo &rarr;</a>
             <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="hero-secondary">
                 <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" style="vertical-align:-2px;margin-right:4px;"><path d="M12 .587l3.668 7.568L24 9.306l-6 5.986 1.416 8.421L12 19.897l-7.416 3.816L6 15.292 0 9.306l8.332-1.151z"/></svg>
                Star on GitHub
             </a>
         </div>

     </div>
</section>

<style>
.hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    padding: 7rem 2rem 5rem;
    background: transparent;
    color: var(--text);
}

.hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
        radial-gradient(circle at 12% 12%, rgba(147, 197, 253, 0.22), transparent 34rem),
        radial-gradient(circle at 82% 22%, rgba(139, 92, 246, 0.24), transparent 34rem),
        linear-gradient(180deg, #fbfdff 0%, #f8f8fd 100%);
    -webkit-mask-image: linear-gradient(180deg, #000 0%, #000 72%, rgba(0, 0, 0, 0.72) 84%, transparent 100%);
    mask-image: linear-gradient(180deg, #000 0%, #000 72%, rgba(0, 0, 0, 0.72) 84%, transparent 100%);
}

.hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/images/hero.jpg');
    background-size: cover;
}

.hero-content {
    position: relative;
    z-index: 1;
    max-width: 820px;
    margin: 0 auto;
}

.hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--border-soft);
    padding: 0.3rem 1rem;
    border-radius: 100px;
    margin-bottom: 2rem;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: var(--shadow-card);
}

.hero-title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 4.5rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
    margin-bottom: 0.75rem;
}

.hero-grad {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.hero-tagline {
    font-size: 1.08rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 900px;
    white-space: nowrap;
    margin-bottom: 1.5rem;
}

.hero-pillars {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    justify-content: center;
}

.pillar {
    font-size: 0.9rem;
    color: var(--text-soft);
    font-weight: 600;
    letter-spacing: 0.01em;
}

.pillar-dot {
    color: var(--accent);
    font-size: 1.2rem;
    line-height: 1;
}

.hero-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
}

.hero-cta {
    background: var(--gradient-primary);
    color: #ffffff;
    padding: 1px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 1.05rem;
    text-decoration: none;
    box-shadow: none;
    transition: transform 0.2s ease;
}

.hero-cta span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 2.5rem;
    border-radius: 999px;
    background: var(--accent);
    transition: background 0.3s ease;
}

.hero-cta:hover {
    text-decoration: none;
}

.hero-cta:hover span,
.hero-cta:focus-visible span {
    background: var(--accent-deep);
}

.hero-demo {
    border: 1.5px solid rgba(88, 43, 232, 0.24);
    color: var(--accent);
    background: rgba(255, 255, 255, 0.68);
    padding: 0.85rem 2.5rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 1.05rem;
    text-decoration: none;
    transition: background 0.3s ease, box-shadow 0.3s ease, transform 0.2s ease;
}

.hero-demo:hover {
    background: #ffffff;
    box-shadow: 0 12px 28px rgba(88, 43, 232, 0.18);
    transform: translateY(-2px);
    text-decoration: none;
}

.hero-secondary {
    color: var(--text-muted);
    font-size: 0.95rem;
    text-decoration: none;
    transition: color 0.2s;
}

.hero-secondary:hover {
    color: var(--accent);
    text-decoration: none;
}

@keyframes heroIn {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
}

.anim {
    opacity: 0;
    animation: heroIn 0.8s ease-out forwards;
}

.anim-1 { animation-delay: 0.1s; }
.anim-2 { animation-delay: 0.3s; }
.anim-3 { animation-delay: 0.55s; }
.anim-4 { animation-delay: 0.75s; }
.anim-5 { animation-delay: 0.95s; }

@media (max-width: 768px) {
    .hero { padding: 5rem 1.5rem 3rem; min-height: auto; }
    .hero-title { margin-bottom: 1.5rem; }
}

@media (max-width: 540px) {
    .hero-actions { flex-direction: column; gap: 0.75rem; width: 100%; max-width: 320px; }
    .hero-cta, .hero-demo { width: 100%; text-align: center; padding: 0.85rem 1.5rem; }
    .hero-pillars { flex-direction: column; gap: 0.4rem; }
    .pillar-dot { display: none; }
}

@media (max-width: 480px) {
    .hero { padding: 4rem 1.25rem 2.25rem; }
}
</style>
