{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gwc.local/schemas/node-interruptibility.schema.json",
  "title": "GWC Runtime Node Interruptibility",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "node_id", "interruptibility"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "node_id": {"type": "string", "minLength": 1},
    "interruptibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["BASE_DRIFT"],
      "properties": {
        "BASE_DRIFT": {
          "type": "object",
          "additionalProperties": false,
          "required": ["supported", "safe_phases", "forbidden_phases", "checkpoint_required", "resume_strategy"],
          "properties": {
            "supported": {"type": "boolean"},
            "safe_phases": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["PRE_ACTION", "POST_ACTION_READBACK", "WAITING", "COMPLETED"]}},
            "forbidden_phases": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["SIDE_EFFECT_IN_FLIGHT"]}},
            "checkpoint_required": {"const": true},
            "resume_strategy": {"enum": ["FROM_CHECKPOINT", "CONTINUE_NEXT_AFTER_READBACK", "REROUTE_ONLY"]}
          }
        }
      }
    }
  }
}
