{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gwc.local/schemas/g3-delivery-record.schema.json",
  "title": "GWC G3 Delivery Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "gate",
    "task_id",
    "repository",
    "base_ref",
    "base_sha",
    "working_branch",
    "pull_request",
    "head_sha",
    "scope_hash",
    "changed_paths",
    "validation",
    "review",
    "ci",
    "residual_risks",
    "exclusions",
    "outcome"
  ],
  "$defs": {
    "sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "scope_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "evidence_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "artifact_type": {
      "const": "g3-delivery-record"
    },
    "gate": {
      "const": "G3_PR"
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "repository": {
      "type": "string",
      "pattern": "^[^/\\s]+/[^/\\s]+$"
    },
    "base_ref": {
      "type": "string",
      "minLength": 1
    },
    "base_sha": {
      "$ref": "#/$defs/sha"
    },
    "working_branch": {
      "type": "string",
      "minLength": 1
    },
    "pull_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number",
        "url",
        "draft"
      ],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "draft": {
          "const": true
        }
      }
    },
    "head_sha": {
      "$ref": "#/$defs/sha"
    },
    "scope_hash": {
      "$ref": "#/$defs/scope_hash"
    },
    "changed_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "head_sha",
        "status",
        "commands"
      ],
      "properties": {
        "head_sha": {
          "$ref": "#/$defs/sha"
        },
        "status": {
          "enum": [
            "pass",
            "fail",
            "not_run"
          ]
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "command",
              "result",
              "evidence"
            ],
            "properties": {
              "command": {
                "type": "string",
                "minLength": 1
              },
              "result": {
                "enum": [
                  "pass",
                  "fail",
                  "skipped"
                ]
              },
              "evidence": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implementer_id",
        "reviewer_id",
        "independence",
        "mode",
        "reviewed_head_sha",
        "reviewed_scope_hash",
        "reviewed_at",
        "lanes",
        "findings",
        "acceptance_criteria",
        "decision",
        "stale"
      ],
      "properties": {
        "implementer_id": {
          "type": "string",
          "minLength": 1
        },
        "reviewer_id": {
          "type": "string",
          "minLength": 1
        },
        "independence": {
          "enum": [
            "independent",
            "fresh-context"
          ]
        },
        "mode": {
          "const": "read-only"
        },
        "reviewed_head_sha": {
          "$ref": "#/$defs/sha"
        },
        "reviewed_scope_hash": {
          "$ref": "#/$defs/scope_hash"
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "lanes": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "applicable",
              "status",
              "evidence"
            ],
            "properties": {
              "name": {
                "enum": [
                  "requirement",
                  "design",
                  "code",
                  "test",
                  "governance",
                  "delivery",
                  "ci"
                ]
              },
              "applicable": {
                "type": "boolean"
              },
              "status": {
                "enum": [
                  "pass",
                  "fail",
                  "not_reviewed",
                  "not_applicable"
                ]
              },
              "evidence": {
                "$ref": "#/$defs/evidence_list"
              }
            }
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "severity",
              "category",
              "status",
              "evidence",
              "recommendation"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^REV-[0-9]+$"
              },
              "severity": {
                "enum": [
                  "BLOCKER",
                  "MAJOR",
                  "MINOR",
                  "NIT"
                ]
              },
              "category": {
                "enum": [
                  "requirement",
                  "design",
                  "code",
                  "test",
                  "security",
                  "governance",
                  "delivery",
                  "ci"
                ]
              },
              "status": {
                "enum": [
                  "open",
                  "resolved",
                  "deferred",
                  "accepted_risk"
                ]
              },
              "evidence": {
                "type": "string",
                "minLength": 1
              },
              "recommendation": {
                "type": "string",
                "minLength": 1
              },
              "resolution": {
                "type": "string",
                "minLength": 1
              },
              "risk_acceptance": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "actor",
                  "source",
                  "accepted_at",
                  "rationale",
                  "head_sha"
                ],
                "properties": {
                  "actor": {
                    "type": "string",
                    "minLength": 1
                  },
                  "source": {
                    "type": "string",
                    "minLength": 1
                  },
                  "accepted_at": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "rationale": {
                    "type": "string",
                    "minLength": 1
                  },
                  "head_sha": {
                    "$ref": "#/$defs/sha"
                  }
                }
              }
            }
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "result",
              "evidence"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^AC-[0-9]+$"
              },
              "result": {
                "enum": [
                  "pass",
                  "fail",
                  "not_verified",
                  "not_applicable"
                ]
              },
              "evidence": {
                "$ref": "#/$defs/evidence_list"
              }
            }
          }
        },
        "decision": {
          "enum": [
            "pass",
            "changes_required",
            "blocked"
          ]
        },
        "stale": {
          "type": "boolean"
        }
      }
    },
    "ci": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "head_sha",
        "checks"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "head_sha": {
          "$ref": "#/$defs/sha"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "required",
              "status",
              "evidence"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "required": {
                "type": "boolean"
              },
              "status": {
                "enum": [
                  "pass",
                  "fail",
                  "pending",
                  "skipped",
                  "cancelled",
                  "neutral"
                ]
              },
              "evidence": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "exclusions": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outcome": {
      "enum": [
        "pass",
        "fail",
        "inconclusive"
      ]
    }
  }
}
