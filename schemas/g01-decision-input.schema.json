{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gwc.local/schemas/g01-decision-input.schema.json",
  "title": "G01 Decision Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "generated_at", "options", "recommended_option_id", "recommendation_rationale", "decision"],
  "$defs": {
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "benefits", "tradeoffs", "risks", "constraint_fit"],
      "properties": {
        "id": {"type": "string", "pattern": "^OPT-[0-9]+$"},
        "title": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "benefits": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "tradeoffs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "risks": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "constraint_fit": {"enum": ["FIT", "PARTIAL", "NOT_FIT"]}
      }
    }
  },
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_type": {"const": "g01-decision-input"},
    "generated_at": {"type": "string", "format": "date-time"},
    "options": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/option"}},
    "recommended_option_id": {
      "oneOf": [
        {"type": "string", "pattern": "^OPT-[0-9]+$"},
        {"type": "null"}
      ]
    },
    "recommendation_rationale": {"type": "string", "minLength": 1},
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "selected_option_id", "actor", "decided_at", "source", "explicit", "rationale", "acceptance_criteria_refs"],
      "properties": {
        "status": {"enum": ["PENDING", "ACCEPTED", "REJECTED"]},
        "selected_option_id": {
          "oneOf": [
            {"type": "string", "pattern": "^OPT-[0-9]+$"},
            {"type": "null"}
          ]
        },
        "actor": {"type": "string", "minLength": 1},
        "decided_at": {"type": "string", "format": "date-time"},
        "source": {"type": "string", "minLength": 1},
        "explicit": {"type": "boolean"},
        "rationale": {"type": "string"},
        "acceptance_criteria_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^AC-[0-9]+$"}
        }
      }
    }
  }
}
