{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gwc.local/schemas/g1-intake-brief.schema.json",
  "title": "G1 Intake Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "generated_at",
    "trace",
    "problem",
    "desired_outcome",
    "stakeholders",
    "scope",
    "constraints",
    "assumptions",
    "risks",
    "acceptance_criteria",
    "unresolved_questions",
    "status"
  ],
  "$defs": {
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "repository",
        "task_id",
        "base_sha",
        "g0_snapshot"
      ],
      "properties": {
        "project_id": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "pattern": "^[^/\\s]+/[^/\\s]+$"
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "base_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "g0_snapshot": {
          "type": "string",
          "const": "../../g0/context-snapshot.yaml"
        }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "statement",
        "verifiable"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^AC-[0-9]+$"
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "verifiable": {
          "type": "boolean"
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "impact",
        "mitigation"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^RISK-[0-9]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "impact": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "mitigation": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "artifact_type": {
      "const": "g1-intake-brief"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace": {
      "$ref": "#/$defs/trace"
    },
    "problem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement",
        "why_now"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "why_now": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "desired_outcome": {
      "type": "string",
      "minLength": 1
    },
    "stakeholders": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requester",
        "affected"
      ],
      "properties": {
        "requester": {
          "type": "string",
          "minLength": 1
        },
        "affected": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "in_scope",
        "non_goals"
      ],
      "properties": {
        "in_scope": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "non_goals": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assumptions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/acceptance"
      }
    },
    "delivery_lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authorized_actions",
        "downstream_non_goals",
        "g3_metadata_completion"
      ],
      "properties": {
        "authorized_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "downstream_non_goals": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "g3_metadata_completion": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ready_for_review_after_g3_pass",
            "required_evidence"
          ],
          "properties": {
            "ready_for_review_after_g3_pass": {
              "type": "boolean"
            },
            "required_evidence": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "unresolved_questions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "enum": [
        "DRAFT",
        "READY",
        "NEEDS_INPUT",
        "BLOCKED"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "READY"
          }
        }
      },
      "then": {
        "properties": {
          "scope": {
            "properties": {
              "in_scope": {
                "minItems": 1
              },
              "non_goals": {
                "minItems": 1
              }
            }
          },
          "acceptance_criteria": {
            "minItems": 1
          },
          "unresolved_questions": {
            "maxItems": 0
          }
        }
      }
    }
  ]
}
