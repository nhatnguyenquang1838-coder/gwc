{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gwc.local/schemas/g01-runtime-input.schema.json",
  "title": "G01 Runtime Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "generated_at", "project", "repository", "runtime", "task", "request", "policies", "sources", "risk"],
  "$defs": {
    "riskItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "impact", "mitigation"],
      "properties": {
        "id": {"type": "string", "pattern": "^RISK-[0-9]+$"},
        "description": {"type": "string", "minLength": 1},
        "impact": {"enum": ["low", "medium", "high"]},
        "mitigation": {"type": "string", "minLength": 1}
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "verifiable"],
      "properties": {
        "id": {"type": "string", "pattern": "^AC-[0-9]+$"},
        "statement": {"type": "string", "minLength": 1},
        "verifiable": {"type": "boolean"}
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "ref", "source_sha"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "ref": {"type": "string", "minLength": 1},
        "source_sha": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "required", "status", "source_sha"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "required": {"type": "boolean"},
        "status": {"enum": ["AVAILABLE", "MISSING", "UNVERIFIED"]},
        "source_sha": {
          "oneOf": [
            {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
            {"type": "null"}
          ]
        }
      }
    }
  },
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_type": {"const": "g01-runtime-input"},
    "generated_at": {"type": "string", "format": "date-time"},
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "profile_path"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "profile_path": {"type": "string", "pattern": "^projects/[^/]+/project-profile\\.yaml$"}
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["full_name", "base_ref", "base_sha", "protected_branches", "connector", "write_enabled", "verified"],
      "properties": {
        "full_name": {"type": "string", "pattern": "^[^/\\s]+/[^/\\s]+$"},
        "base_ref": {"type": "string", "minLength": 1},
        "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "protected_branches": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "connector": {"type": "string", "minLength": 1},
        "write_enabled": {"type": "boolean"},
        "verified": {"type": "boolean"}
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_runtime_id", "execution_mode", "selected_profile", "connector_priority", "selected_connector", "connector_fallback_evidence", "required_behavior_contracts"],
      "properties": {
        "agent_runtime_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$"},
        "execution_mode": {"enum": ["chat_connector_only", "local_agent", "repo_ci"]},
        "selected_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "path", "status", "source_sha", "supported_execution_modes"],
          "properties": {
            "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$"},
            "path": {"type": "string", "pattern": "^governance/agent-runtime-profiles/[^/]+\\.ya?ml$"},
            "status": {"const": "active"},
            "source_sha": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
            "supported_execution_modes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"enum": ["chat_connector_only", "local_agent", "repo_ci"]}
            }
          }
        },
        "connector_priority": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "selected_connector": {"type": "string", "minLength": 1},
        "connector_fallback_evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["connector", "role", "status", "evidence"],
            "properties": {
              "connector": {"type": "string", "minLength": 1},
              "role": {"enum": ["primary", "fallback"]},
              "status": {"enum": ["AVAILABLE", "UNAVAILABLE", "SKIPPED"]},
              "evidence": {"type": "string", "minLength": 1}
            }
          }
        },
        "required_behavior_contracts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source"}}
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "claimed"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "claimed": {"type": "boolean"}
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requester", "problem", "desired_outcome", "affected", "in_scope", "non_goals", "constraints", "assumptions", "risks", "acceptance_criteria", "unresolved_questions"],
      "properties": {
        "requester": {"type": "string", "minLength": 1},
        "problem": {
          "type": "object",
          "additionalProperties": false,
          "required": ["statement", "why_now"],
          "properties": {
            "statement": {"type": "string", "minLength": 1},
            "why_now": {"type": "string", "minLength": 1}
          }
        },
        "desired_outcome": {"type": "string", "minLength": 1},
        "affected": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "in_scope": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "non_goals": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "constraints": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "assumptions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "risks": {"type": "array", "items": {"$ref": "#/$defs/riskItem"}},
        "acceptance_criteria": {"type": "array", "items": {"$ref": "#/$defs/acceptance"}},
        "unresolved_questions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "policies": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/policy"}},
    "sources": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source"}},
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "human_direction_confirmed"],
      "properties": {
        "class": {"enum": ["R0", "R1", "R2", "R3"]},
        "human_direction_confirmed": {"type": "boolean"}
      }
    }
  }
}
