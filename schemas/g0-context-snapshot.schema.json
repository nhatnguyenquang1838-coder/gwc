{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gwc.local/schemas/g0-context-snapshot.schema.json",
  "title": "G0 Context Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "generated_at",
    "project",
    "repository",
    "constraints",
    "applicable_policies",
    "sources",
    "status",
    "blockers"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "artifact_type": {
      "const": "g0-context-snapshot"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "profile_path"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "profile_path": {
          "type": "string",
          "pattern": "^projects/[^/]+/project-profile\\.yaml$"
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "full_name",
        "base_ref",
        "base_sha",
        "protected_branches",
        "connector",
        "write_enabled"
      ],
      "properties": {
        "full_name": {
          "type": "string",
          "pattern": "^[^/\\s]+/[^/\\s]+$"
        },
        "base_ref": {
          "type": "string",
          "minLength": 1
        },
        "base_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "protected_branches": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "connector": {
          "type": "string",
          "minLength": 1
        },
        "write_enabled": {
          "type": "boolean"
        }
      }
    },
    "constraints": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "applicable_policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "path",
          "ref",
          "source_sha"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "source_sha": {
            "type": "string",
            "pattern": "^[0-9a-f]{40,64}$"
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "required",
          "status",
          "source_sha"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "status": {
            "enum": [
              "AVAILABLE",
              "MISSING",
              "UNVERIFIED"
            ]
          },
          "source_sha": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^[0-9a-f]{40,64}$"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      }
    },
    "status": {
      "enum": [
        "READY",
        "BLOCKED"
      ]
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "contextual_discovery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "historical_context": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "description",
              "link"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "link": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        },
        "downstream_impact": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "target",
              "impact_type"
            ],
            "properties": {
              "target": {
                "type": "string",
                "minLength": 1
              },
              "impact_type": {
                "enum": [
                  "BREAKING",
                  "NON_BREAKING",
                  "SCHEMA_CHANGE",
                  "DATA_MIGRATION"
                ]
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "stakeholder_reach": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "persona",
              "impact"
            ],
            "properties": {
              "persona": {
                "type": "string",
                "minLength": 1
              },
              "impact": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "READY"
          }
        }
      },
      "then": {
        "properties": {
          "blockers": {
            "maxItems": 0
          }
        }
      }
    }
  ]
}
