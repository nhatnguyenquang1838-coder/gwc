{
  "$id": "https://gwc.local/schemas/node-architect/runtime-event.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "actor": {
      "additionalProperties": false,
      "properties": {
        "execution_mode": {"enum": ["chat_connector_only", "local_agent", "repo_ci"]},
        "id": {"minLength": 1, "type": "string"},
        "kind": {"enum": ["chatgpt", "dwc", "dw1", "kiro", "github_actions", "human"]}
      },
      "required": ["kind", "id", "execution_mode"],
      "type": "object"
    },
    "bypass": {
      "additionalProperties": false,
      "properties": {
        "bypass_request_id": {"pattern": "^HB-[A-Z0-9][A-Z0-9_-]+$", "type": "string"},
        "blocked_step_id": {"minLength": 1, "type": "string"},
        "scope_hash": {"pattern": "^sha256:[0-9a-f]{64}$", "type": "string"}
      },
      "required": ["bypass_request_id", "blocked_step_id", "scope_hash"],
      "type": "object"
    },
    "checkpoint_id": {"minLength": 1, "type": "string"},
    "event_id": {"pattern": "^evt_[a-z0-9._-]+$", "type": "string"},
    "event_type": {
      "enum": [
        "node_started", "side_effect_scheduled", "side_effect_completed", "side_effect_failed",
        "checkpoint_written", "suspend_requested", "resume_requested", "evidence_invalidated",
        "gate_passed", "gate_failed", "human_bypass_requested", "human_bypass_accepted",
        "human_bypass_evidence_verified", "human_bypass_expired", "human_bypass_rejected"
      ]
    },
    "gate": {"enum": ["G0_CONTEXT", "G1_ALIGNMENT", "G2_EXECUTION", "G3_PR", "G4_MERGE", "G5_DEPLOY", "G6_PRODUCTION_DATA"]},
    "idempotency_key": {"type": "string"},
    "node_id": {"pattern": "^[a-z0-9][a-z0-9._-]*$", "type": "string"},
    "occurred_at_utc": {"format": "date-time", "type": "string"},
    "outcome": {"enum": ["pending", "success", "failure", "blocked", "superseded", "expired", "rejected"]},
    "repository": {
      "additionalProperties": false,
      "properties": {
        "base_branch": {"type": "string"}, "base_sha": {"pattern": "^[0-9a-f]{40}$", "type": "string"},
        "branch": {"type": "string"}, "full_name": {"pattern": "^[^/]+/[^/]+$", "type": "string"},
        "head_sha": {"pattern": "^[0-9a-f]{40}$", "type": "string"}
      },
      "required": ["full_name"], "type": "object"
    },
    "schema_version": {"const": "0.1"}
  },
  "required": ["schema_version", "event_id", "event_type", "occurred_at_utc", "actor", "node_id", "gate", "outcome"],
  "allOf": [
    {
      "if": {"properties": {"event_type": {"enum": ["human_bypass_requested", "human_bypass_accepted", "human_bypass_evidence_verified", "human_bypass_expired", "human_bypass_rejected"]}}},
      "then": {"required": ["bypass", "checkpoint_id", "idempotency_key"]}
    }
  ],
  "title": "GWC Runtime Event",
  "type": "object"
}
