{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gwc.local/schemas/node-architect/failure-simulation-matrix.schema.json",
  "title": "Failure Simulation Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "matrix_id", "scale_81_nodes_allowed", "required_cases"],
  "properties": {
    "schema_version": {"const": "0.1"},
    "matrix_id": {"type": "string", "minLength": 1},
    "scale_81_nodes_allowed": {"const": false},
    "required_cases": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "trigger", "expected_response", "forbidden_behaviors", "evidence_required"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "trigger": {"type": "string", "minLength": 1},
          "expected_response": {"type": "string", "minLength": 1},
          "forbidden_behaviors": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "evidence_required": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}
