{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gwc.local/schemas/node-architect/g5-ci-checkpoint.schema.json",
  "title": "G5 CI Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "checkpoint_type",
    "task_id",
    "repository",
    "gate",
    "merge_commit_sha",
    "required_workflows",
    "observed_runs",
    "selected_run_ids",
    "status",
    "next_check_after",
    "continuation_mechanism",
    "attempt",
    "max_attempts"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "checkpoint_type": {"const": "g5-ci-status-verify"},
    "task_id": {"type": "string", "minLength": 1},
    "repository": {"type": "string", "pattern": "^[^/\\s]+/[^/\\s]+$"},
    "gate": {"const": "G5_DEPLOY"},
    "merge_commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "scope_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "required_workflows": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "observed_runs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["run_id", "workflow", "head_sha", "status"],
        "properties": {
          "run_id": {"type": "integer", "minimum": 1},
          "workflow": {"type": "string", "minLength": 1},
          "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
          "status": {"type": "string", "minLength": 1},
          "conclusion": {"type": ["string", "null"]}
        }
      }
    },
    "selected_run_ids": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1}
    },
    "status": {"enum": ["pending", "resumed", "expired", "superseded", "completed"]},
    "next_check_after": {"type": "string", "format": "date-time"},
    "continuation_mechanism": {"enum": ["webhook", "local_poll", "scheduled_task", "manual_checkpoint"]},
    "attempt": {"type": "integer", "minimum": 1},
    "max_attempts": {"type": "integer", "minimum": 1},
    "last_checked_at": {"type": "string", "format": "date-time"},
    "resume_token": {"type": "string"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "pending"}}},
      "then": {"properties": {"attempt": {"minimum": 1}}}
    }
  ]
}
